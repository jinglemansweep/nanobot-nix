# =============================================================================
# nanobot-nix Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values you need.
# All variables are optional unless noted otherwise.

# =============================================================================
# Provider API Keys
# =============================================================================

NANOBOT_PROVIDERS_OPENROUTER_APIKEY=        # Alias: OPENROUTER_API_KEY
NANOBOT_PROVIDERS_OPENROUTER_APIBASE=
NANOBOT_PROVIDERS_ANTHROPIC_APIKEY=         # Alias: ANTHROPIC_API_KEY
NANOBOT_PROVIDERS_ANTHROPIC_APIBASE=
NANOBOT_PROVIDERS_OPENAI_APIKEY=            # Alias: OPENAI_API_KEY
NANOBOT_PROVIDERS_DEEPSEEK_APIKEY=          # Alias: DEEPSEEK_API_KEY
NANOBOT_PROVIDERS_GROQ_APIKEY=              # Alias: GROQ_API_KEY
NANOBOT_PROVIDERS_ZHIPU_APIKEY=             # Alias: ZHIPU_API_KEY
NANOBOT_PROVIDERS_ZHIPU_APIBASE=
NANOBOT_PROVIDERS_CUSTOM_APIKEY=
NANOBOT_PROVIDERS_CUSTOM_APIBASE=

# =============================================================================
# Agent Config
# =============================================================================

NANOBOT_AGENTS_DEFAULTS_MODEL=anthropic/claude-sonnet-4-5-20250514  # Alias: NANOBOT_MODEL

# =============================================================================
# Channel Config — Telegram
# =============================================================================

NANOBOT_CHANNELS_TELEGRAM_ENABLED=          # true/false
NANOBOT_CHANNELS_TELEGRAM_TOKEN=            # Alias: TELEGRAM_BOT_TOKEN
NANOBOT_CHANNELS_TELEGRAM_ALLOWFROM=        # Comma-separated list (e.g. user1,user2)

# =============================================================================
# Channel Config — Discord
# =============================================================================

NANOBOT_CHANNELS_DISCORD_ENABLED=           # true/false
NANOBOT_CHANNELS_DISCORD_TOKEN=
NANOBOT_CHANNELS_DISCORD_ALLOWFROM=         # Comma-separated list (e.g. user1,user2)

# =============================================================================
# Channel Config — Slack
# =============================================================================

NANOBOT_CHANNELS_SLACK_ENABLED=             # true/false
NANOBOT_CHANNELS_SLACK_APPTOKEN=
NANOBOT_CHANNELS_SLACK_BOTTOKEN=
NANOBOT_CHANNELS_SLACK_ALLOWFROM=           # Comma-separated list (e.g. user1,user2)

# =============================================================================
# Channel Config — WhatsApp
# =============================================================================

NANOBOT_CHANNELS_WHATSAPP_ENABLED=          # true/false
NANOBOT_CHANNELS_WHATSAPP_ALLOWFROM=        # Comma-separated list (e.g. user1,user2)

# =============================================================================
# Tools Config
# =============================================================================

NANOBOT_TOOLS_WEB_SEARCH_APIKEY=            # Alias: BRAVE_SEARCH_API_KEY
NANOBOT_TOOLS_MCPSERVERS=                   # JSON blob (e.g. {"server1":{"command":"npx","args":[...]}})

# =============================================================================
# Nix Config
# =============================================================================

# Controls which Nix packages the agent can install:
#   * = allow all packages
#   pkg1,pkg2,pkg3 = allow only listed packages
#   (empty/unset) = deny all package installations
NANOBOT_NIX_ALLOWED_PACKAGES=
