# =============================================================================
# nanobot-nix Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values you need.
# All variables are optional.
#
# Naming convention:
#   NANOBOT_ prefix, __ (double underscore) nested delimiter,
#   UPPERCASE_SNAKE_CASE field names.
#
# Example: NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=sk-...

# =============================================================================
# Provider API Keys
# =============================================================================
# Each provider also supports EXTRA_HEADERS (JSON object) for custom headers,
# e.g. NANOBOT_PROVIDERS__AIHUBMIX__EXTRA_HEADERS={"APP-Code":"xxx"}

# --- Commonly Used Providers ---

NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=
NANOBOT_PROVIDERS__ANTHROPIC__API_BASE=

NANOBOT_PROVIDERS__OPENAI__API_KEY=
NANOBOT_PROVIDERS__OPENAI__API_BASE=

NANOBOT_PROVIDERS__OPENROUTER__API_KEY=
NANOBOT_PROVIDERS__OPENROUTER__API_BASE=

NANOBOT_PROVIDERS__DEEPSEEK__API_KEY=
NANOBOT_PROVIDERS__DEEPSEEK__API_BASE=

NANOBOT_PROVIDERS__GROQ__API_KEY=
NANOBOT_PROVIDERS__GROQ__API_BASE=

# --- Additional Providers ---

NANOBOT_PROVIDERS__GEMINI__API_KEY=
NANOBOT_PROVIDERS__GEMINI__API_BASE=

NANOBOT_PROVIDERS__ZHIPU__API_KEY=
NANOBOT_PROVIDERS__ZHIPU__API_BASE=

NANOBOT_PROVIDERS__DASHSCOPE__API_KEY=
NANOBOT_PROVIDERS__DASHSCOPE__API_BASE=

NANOBOT_PROVIDERS__MOONSHOT__API_KEY=
NANOBOT_PROVIDERS__MOONSHOT__API_BASE=

NANOBOT_PROVIDERS__MINIMAX__API_KEY=
NANOBOT_PROVIDERS__MINIMAX__API_BASE=

NANOBOT_PROVIDERS__AIHUBMIX__API_KEY=
NANOBOT_PROVIDERS__AIHUBMIX__API_BASE=

NANOBOT_PROVIDERS__SILICONFLOW__API_KEY=
NANOBOT_PROVIDERS__SILICONFLOW__API_BASE=

NANOBOT_PROVIDERS__VOLCENGINE__API_KEY=
NANOBOT_PROVIDERS__VOLCENGINE__API_BASE=

NANOBOT_PROVIDERS__VLLM__API_KEY=
NANOBOT_PROVIDERS__VLLM__API_BASE=

NANOBOT_PROVIDERS__OPENAI_CODEX__API_KEY=
NANOBOT_PROVIDERS__OPENAI_CODEX__API_BASE=

NANOBOT_PROVIDERS__GITHUB_COPILOT__API_KEY=
NANOBOT_PROVIDERS__GITHUB_COPILOT__API_BASE=

NANOBOT_PROVIDERS__CUSTOM__API_KEY=
NANOBOT_PROVIDERS__CUSTOM__API_BASE=

# =============================================================================
# Agent Defaults
# =============================================================================

NANOBOT_AGENTS__DEFAULTS__MODEL=                    # e.g. anthropic/claude-opus-4-5
NANOBOT_AGENTS__DEFAULTS__PROVIDER=                 # e.g. auto, anthropic, openrouter
NANOBOT_AGENTS__DEFAULTS__WORKSPACE=                # e.g. ~/.nanobot/workspace
NANOBOT_AGENTS__DEFAULTS__MAX_TOKENS=               # int
NANOBOT_AGENTS__DEFAULTS__TEMPERATURE=              # float
NANOBOT_AGENTS__DEFAULTS__MAX_TOOL_ITERATIONS=      # int
NANOBOT_AGENTS__DEFAULTS__MEMORY_WINDOW=            # int

# =============================================================================
# Channel Settings
# =============================================================================

NANOBOT_CHANNELS__SEND_PROGRESS=                    # bool
NANOBOT_CHANNELS__SEND_TOOL_HINTS=                  # bool

# =============================================================================
# Channel — Telegram
# =============================================================================

NANOBOT_CHANNELS__TELEGRAM__ENABLED=                # bool
NANOBOT_CHANNELS__TELEGRAM__TOKEN=
NANOBOT_CHANNELS__TELEGRAM__ALLOW_FROM=             # JSON array (e.g. ["user1","user2"])
NANOBOT_CHANNELS__TELEGRAM__PROXY=
NANOBOT_CHANNELS__TELEGRAM__REPLY_TO_MESSAGE=       # bool

# =============================================================================
# Channel — Discord
# =============================================================================

NANOBOT_CHANNELS__DISCORD__ENABLED=                 # bool
NANOBOT_CHANNELS__DISCORD__TOKEN=
NANOBOT_CHANNELS__DISCORD__ALLOW_FROM=              # JSON array (e.g. ["user1","user2"])
NANOBOT_CHANNELS__DISCORD__GATEWAY_URL=
NANOBOT_CHANNELS__DISCORD__INTENTS=                 # int

# =============================================================================
# Channel — Slack
# =============================================================================

NANOBOT_CHANNELS__SLACK__ENABLED=                   # bool
NANOBOT_CHANNELS__SLACK__MODE=                      # e.g. socket
NANOBOT_CHANNELS__SLACK__WEBHOOK_PATH=
NANOBOT_CHANNELS__SLACK__BOT_TOKEN=
NANOBOT_CHANNELS__SLACK__APP_TOKEN=
NANOBOT_CHANNELS__SLACK__USER_TOKEN_READ_ONLY=      # bool
NANOBOT_CHANNELS__SLACK__REPLY_IN_THREAD=           # bool
NANOBOT_CHANNELS__SLACK__REACT_EMOJI=
NANOBOT_CHANNELS__SLACK__GROUP_POLICY=              # mention/open/allowlist
NANOBOT_CHANNELS__SLACK__GROUP_ALLOW_FROM=          # JSON array (e.g. ["channel1","channel2"])
NANOBOT_CHANNELS__SLACK__DM__ENABLED=               # bool
NANOBOT_CHANNELS__SLACK__DM__POLICY=                # open/allowlist
NANOBOT_CHANNELS__SLACK__DM__ALLOW_FROM=            # JSON array (e.g. ["user1","user2"])

# =============================================================================
# Channel — WhatsApp
# =============================================================================

NANOBOT_CHANNELS__WHATSAPP__ENABLED=                # bool
NANOBOT_CHANNELS__WHATSAPP__BRIDGE_URL=
NANOBOT_CHANNELS__WHATSAPP__BRIDGE_TOKEN=
NANOBOT_CHANNELS__WHATSAPP__ALLOW_FROM=             # JSON array (e.g. ["user1","user2"])

# =============================================================================
# Channel — Email
# =============================================================================

NANOBOT_CHANNELS__EMAIL__ENABLED=                   # bool
NANOBOT_CHANNELS__EMAIL__CONSENT_GRANTED=           # bool

# IMAP (receive)
NANOBOT_CHANNELS__EMAIL__IMAP_HOST=
NANOBOT_CHANNELS__EMAIL__IMAP_PORT=                 # int
NANOBOT_CHANNELS__EMAIL__IMAP_USERNAME=
NANOBOT_CHANNELS__EMAIL__IMAP_PASSWORD=
NANOBOT_CHANNELS__EMAIL__IMAP_MAILBOX=
NANOBOT_CHANNELS__EMAIL__IMAP_USE_SSL=              # bool

# SMTP (send)
NANOBOT_CHANNELS__EMAIL__SMTP_HOST=
NANOBOT_CHANNELS__EMAIL__SMTP_PORT=                 # int
NANOBOT_CHANNELS__EMAIL__SMTP_USERNAME=
NANOBOT_CHANNELS__EMAIL__SMTP_PASSWORD=
NANOBOT_CHANNELS__EMAIL__SMTP_USE_TLS=              # bool
NANOBOT_CHANNELS__EMAIL__SMTP_USE_SSL=              # bool
NANOBOT_CHANNELS__EMAIL__FROM_ADDRESS=

# Behavior
NANOBOT_CHANNELS__EMAIL__AUTO_REPLY_ENABLED=        # bool
NANOBOT_CHANNELS__EMAIL__POLL_INTERVAL_SECONDS=     # int
NANOBOT_CHANNELS__EMAIL__MARK_SEEN=                 # bool
NANOBOT_CHANNELS__EMAIL__MAX_BODY_CHARS=            # int
NANOBOT_CHANNELS__EMAIL__SUBJECT_PREFIX=
NANOBOT_CHANNELS__EMAIL__ALLOW_FROM=                # JSON array (e.g. ["user@example.com"])

# =============================================================================
# Channel — Matrix
# =============================================================================

NANOBOT_CHANNELS__MATRIX__ENABLED=                  # bool
NANOBOT_CHANNELS__MATRIX__HOMESERVER=
NANOBOT_CHANNELS__MATRIX__ACCESS_TOKEN=
NANOBOT_CHANNELS__MATRIX__USER_ID=
NANOBOT_CHANNELS__MATRIX__DEVICE_ID=
NANOBOT_CHANNELS__MATRIX__E2EE_ENABLED=             # bool
NANOBOT_CHANNELS__MATRIX__SYNC_STOP_GRACE_SECONDS=  # int
NANOBOT_CHANNELS__MATRIX__MAX_MEDIA_BYTES=          # int
NANOBOT_CHANNELS__MATRIX__ALLOW_FROM=               # JSON array (e.g. ["@user:matrix.org"])
NANOBOT_CHANNELS__MATRIX__GROUP_POLICY=             # open/mention/allowlist
NANOBOT_CHANNELS__MATRIX__GROUP_ALLOW_FROM=         # JSON array (e.g. ["!roomid:matrix.org"])
NANOBOT_CHANNELS__MATRIX__ALLOW_ROOM_MENTIONS=      # bool

# =============================================================================
# Channel — Feishu
# =============================================================================

NANOBOT_CHANNELS__FEISHU__ENABLED=                  # bool
NANOBOT_CHANNELS__FEISHU__APP_ID=
NANOBOT_CHANNELS__FEISHU__APP_SECRET=
NANOBOT_CHANNELS__FEISHU__ENCRYPT_KEY=
NANOBOT_CHANNELS__FEISHU__VERIFICATION_TOKEN=
NANOBOT_CHANNELS__FEISHU__ALLOW_FROM=               # JSON array

# =============================================================================
# Channel — DingTalk
# =============================================================================

NANOBOT_CHANNELS__DINGTALK__ENABLED=                # bool
NANOBOT_CHANNELS__DINGTALK__CLIENT_ID=
NANOBOT_CHANNELS__DINGTALK__CLIENT_SECRET=
NANOBOT_CHANNELS__DINGTALK__ALLOW_FROM=             # JSON array

# =============================================================================
# Channel — QQ
# =============================================================================

NANOBOT_CHANNELS__QQ__ENABLED=                      # bool
NANOBOT_CHANNELS__QQ__APP_ID=
NANOBOT_CHANNELS__QQ__SECRET=
NANOBOT_CHANNELS__QQ__ALLOW_FROM=                   # JSON array

# =============================================================================
# Channel — Mochat
# =============================================================================
# Mochat has complex config; see upstream docs for full options.

NANOBOT_CHANNELS__MOCHAT__ENABLED=                  # bool
NANOBOT_CHANNELS__MOCHAT__BASE_URL=
NANOBOT_CHANNELS__MOCHAT__CLAW_TOKEN=
NANOBOT_CHANNELS__MOCHAT__AGENT_USER_ID=

# =============================================================================
# Gateway
# =============================================================================

NANOBOT_GATEWAY__HOST=
NANOBOT_GATEWAY__PORT=                              # int
NANOBOT_GATEWAY__HEARTBEAT__ENABLED=                # bool
NANOBOT_GATEWAY__HEARTBEAT__INTERVAL_S=             # int

# =============================================================================
# Tools
# =============================================================================

NANOBOT_TOOLS__WEB__SEARCH__API_KEY=
NANOBOT_TOOLS__WEB__SEARCH__MAX_RESULTS=            # int
NANOBOT_TOOLS__EXEC__TIMEOUT=                       # int
NANOBOT_TOOLS__EXEC__PATH_APPEND=
NANOBOT_TOOLS__RESTRICT_TO_WORKSPACE=               # bool
NANOBOT_TOOLS__MCP_SERVERS=                         # JSON object (e.g. {"server1":{"command":"npx","args":[...]}})

# =============================================================================
# Nix Config
# =============================================================================

# Controls which Nix packages the agent can install:
#   * = allow all packages
#   pkg1,pkg2,pkg3 = allow only listed packages
#   (empty/unset) = deny all package installations
NANOBOT_NIX_ALLOWED_PACKAGES=
